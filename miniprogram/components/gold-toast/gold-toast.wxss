/* gold-toast.wxss */
/* 品牌金色风格操作反馈提示，与小程序整体深色导航 + 金色主调保持一致 */

/* ── 遮罩层（固定定位，覆盖全屏，不拦截点击） ── */
.gt-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.gt-mask.gt-visible {
  opacity: 1;
}

/* ── 提示框主体 ── */
.gt-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
  max-width: 280rpx;
  padding: 48rpx 40rpx 44rpx;
  border-radius: 24rpx;
  transform: scale(0.85);
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.gt-mask.gt-visible .gt-box {
  transform: scale(1);
}

/* 成功 - 深色底 + 金色图标，与页面导航栏风格呼应 */
.gt-box.gt-success {
  background: rgba(26, 31, 46, 0.94);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.36), 0 0 0 1rpx rgba(200, 160, 82, 0.2);
}

/* 错误 - 深色底，与成功一致，避免色彩跳跃 */
.gt-box.gt-error {
  background: rgba(26, 31, 46, 0.94);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.36), 0 0 0 1rpx rgba(231, 76, 60, 0.2);
}

/* 纯文字 - 深色底，横向加宽 */
.gt-box.gt-none {
  background: rgba(26, 31, 46, 0.94);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
  min-width: 240rpx;
  max-width: 480rpx;
  padding: 36rpx 48rpx;
}

/* ── 图标容器 ── */
.gt-icon-wrap {
  margin-bottom: 28rpx;
}

/* ── 圆形图标底盘 ── */
.gt-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 成功：金色，与购物车勾选图标颜色一致 */
.gt-circle-success {
  background: #c8a052;
  box-shadow: 0 8rpx 24rpx rgba(200, 160, 82, 0.45);
}

/* 错误：暖红 */
.gt-circle-error {
  background: #c0392b;
  box-shadow: 0 8rpx 24rpx rgba(192, 57, 43, 0.4);
}

/* ── 图标字符（✓ / ✕） ── */
.gt-icon-text {
  color: #fff;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 600;
}

/* ── 提示文字 ── */
.gt-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  text-align: center;
  letter-spacing: 1rpx;
  line-height: 1.5;
  font-weight: 400;
}

/* 纯文字模式字号稍大 */
.gt-title-only {
  font-size: 30rpx;
}
